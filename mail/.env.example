# Auto-Hub Mail Control Panel — Environment Example
# Copy this file to .env and fill in real values before running.

# Database
DB_DRIVER=sqlite
DATABASE_PATH=data/mail.db
DATABASE_URL=postgres://user:password@localhost/mail?sslmode=disable

# HTTP Server
SERVER_PORT=8080

# Session & Cookie Security
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_MAX_AGE_MINUTES=1440
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax

# CSRF
CSRF_SECRET=change-me-to-another-long-random-string

# Operator (super-admin) login
OPERATOR_PASSWORD=fa2720ee3bf284e3ac21825dffdb1c75
OPERATOR_PASSWORD_HASH=
OPERATOR_SESSION_SECRET=operator-change-me
OPERATOR_LOGIN_PATH=/operator/login
OPERATOR_LOGOUT_PATH=

# Mail Provider: dev_db | imap
MAIL_PROVIDER=dev_db

# SMTP Outbound (used by dev_db and imap providers for external recipients)
SMTP_ENABLED=false
SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_REQUIRE_TLS=false

# IMAP (used when MAIL_PROVIDER=imap)
IMAP_HOST=127.0.0.1
IMAP_PORT=143
IMAP_USE_SSL=false
IMAP_SKIP_TLS_VERIFY=true
IMAP_MASTER_PASSWORD=

# Upload limits
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=10
OPERATOR_RATE_LIMIT_MAX=3
OPERATOR_RATE_LIMIT_WINDOW_MINUTES=15
SEND_RATE_LIMIT_MAX=20
SEND_RATE_LIMIT_WINDOW_MINUTES=10
DRAFT_RATE_LIMIT_MAX=60
DRAFT_RATE_LIMIT_WINDOW_MINUTES=10

# Internal API for web service integration
INTERNAL_API_ENABLED=false
INTERNAL_API_TOKEN=change-me-to-a-long-random-token

# Migrations & Seeding (disable in production)
RUN_MIGRATIONS=true
RUN_SEED=false

GIN_MODE=release
