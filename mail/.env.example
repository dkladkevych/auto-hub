DATABASE_PATH=mail.db
SERVER_PORT=8080
SESSION_SECRET=change-me-in-production-32-char-min
SESSION_MAX_AGE_MINUTES=1440
RUN_MIGRATIONS=true
RUN_SEED=false

# Operator (super-admin) access
# Set EITHER plain password (dev only) OR bcrypt hash (production)
OPERATOR_PASSWORD=
OPERATOR_PASSWORD_HASH=$2a$10$...
OPERATOR_SESSION_SECRET=operator-change-me
